{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velocity Download Manager",
  "version": "2.0.1",
  "identifier": "com.velocitydownloader.app",
  "build": {},
  "app": {
    "windows": [
      {
        "title": "Velocity Download Manager",
        "width": 980,
        "height": 620,
        "minWidth": 760,
        "minHeight": 480,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Backend Tech inc",
    "createUpdaterArtifacts": false,
    "resources": {
      "../extension": "extension",
      "../bin/yt-dlp.exe": "bin/yt-dlp.exe",
      "icons": "icons"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  }
}
