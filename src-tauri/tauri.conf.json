{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velocity Downloader",
  "version": "0.2.1",
  "identifier": "com.velocitydownloader.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Velocity Downloader",
        "width": 980,
        "height": 620,
        "minWidth": 760,
        "minHeight": 480,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../extension": "extension"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRERDZENTlBRUFERjhCRTEKUldUaGk5L3FtdFhXVGQrRVRLcVpVbDl0T082VGJIS0hxSm8zNnc2b0dGb01UY284QUYzV3JhWHYK",
      "endpoints": [
        "https://github.com/hasi98/Velocity-Downloader/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
