import { Button, LineEdit, ScrollView, TextEdit } from "std-widgets.slint";

global AppAssets {
    out property <image> icon: @image-url("../icons/32x32.png");
}

export struct DownloadRow {
    id: string,
    filename: string,
    size: string,
    status: string,
    time_left: string,
    rate: string,
    category: string,
    progress: float,
    stripe: bool,
    selected: bool,
}

export struct SegmentRow {
    number: string,
    downloaded: string,
    status: string,
    progress: float,
}

export struct QualityOption {
    id: string,
    label: string,
    size: string,
    size_bytes: string,
}

export struct BatchQueueRow {
    index: string,
    url: string,
    status: string,
    progress: float,
    error: string,
    active: bool,
}

component MenuItem inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <bool> hot-tracking;
    in property <length> item-width: 64px;
    callback clicked(string);
    callback hovered(string);

    width: root.item-width;
    height: 27px;
    background: selected ? #343434 : touch.has-hover ? #2f2f2f : transparent;

    Text {
        text: root.label;
        color: #ffffff;
        font-size: 12px;
        x: 7px;
        width: root.width - 14px;
        height: root.height;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        clicked => { root.clicked(root.label); }
        moved => {
            if root.hot-tracking {
                root.hovered(root.label);
            }
        }
        pointer-event(event) => {
            if root.hot-tracking && event.kind == PointerEventKind.move {
                root.hovered(root.label);
            }
        }
    }
}

component DropdownItem inherits Rectangle {
    in property <string> label;
    in property <string> action;
    in property <bool> enabled: true;
    callback clicked(string);

    height: 28px;
    background: root.enabled && touch.has-hover ? #094771 : #252526;
    border-width: 0px;

    Text {
        text: root.label;
        color: root.enabled ? (touch.has-hover ? #ffffff : #cccccc) : #555555;
        font-size: 13px;
        x: 12px;
        width: root.width - 24px;
        height: root.height;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(root.action); }
    }
}

component DropdownSeparator inherits Rectangle {
    height: 1px;
    background: #3a3a3a;
}

component MenuDropdown inherits Rectangle {
    in property <string> menu;
    in property <bool> categories-visible: true;
    callback action(string);

    width: 206px;
    background: #252526;
    border-width: 2px;
    border-color: #ffffff;

    if root.menu == "Tasks": VerticalLayout {
        spacing: 0px;
        DropdownItem { label: "Add new download"; action: "add-download"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Add batch download"; action: "add-batch"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Exit"; action: "exit"; clicked(action) => { root.action(action); } }
    }

    if root.menu == "File": VerticalLayout {
        spacing: 0px;
        DropdownItem { label: "Resume Download"; action: "resume"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Stop download"; action: "stop"; clicked(action) => { root.action(action); } }
        DropdownSeparator { }
        DropdownItem { label: "Redownload"; action: "redownload"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Download now"; action: "download-now"; clicked(action) => { root.action(action); } }
    }

    if root.menu == "Downloads": VerticalLayout {
        spacing: 0px;
        DropdownItem { label: "Delete all completed"; action: "delete-completed"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Find"; action: "find"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Speed limiter"; action: "speed-limiter"; clicked(action) => { root.action(action); } }
    }

    if root.menu == "View": VerticalLayout {
        spacing: 0px;
        DropdownItem { label: root.categories-visible ? "Hide categories" : "View categories"; action: "toggle-categories"; clicked(action) => { root.action(action); } }
        DropdownSeparator { }
        DropdownItem { label: "Arrange by date"; action: "arrange-date"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Arrange by last updated"; action: "arrange-updated"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Arrange by file name"; action: "arrange-name"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Arrange by size"; action: "arrange-size"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Arrange by status"; action: "arrange-status"; clicked(action) => { root.action(action); } }
    }

    if root.menu == "Help": VerticalLayout {
        spacing: 0px;
        DropdownItem { label: "Check for updates"; action: "check-updates"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "About"; action: "about"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Homepage"; action: "homepage"; clicked(action) => { root.action(action); } }
        DropdownItem { label: "Support"; action: "support"; clicked(action) => { root.action(action); } }
    }
}

component ContextActionItem inherits Rectangle {
    in property <string> label;
    in property <string> action;
    in property <bool> enabled: true;
    in property <bool> has-sub-menu: false;
    callback selected(string);

    height: 28px;
    background: enabled && touch.has-hover ? #e8f0fe : #ffffff;

    Text {
        text: root.label;
        color: root.enabled ? #111111 : #777777;
        font-size: 13px;
        x: 12px;
        width: root.width - (root.has-sub-menu ? 28px : 20px);
        height: root.height;
        vertical-alignment: center;
        overflow: elide;
    }

    if root.has-sub-menu: Text {
        text: "\u{E974}";
        font-family: "Segoe MDL2 Assets";
        color: #111111;
        font-size: 11px;
        x: root.width - 20px;
        width: 12px;
        height: root.height;
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.selected(root.action); }
    }
}

component ContextSeparator inherits Rectangle {
    height: 1px;
    background: #d0d0d0;
}

component DownloadContextMenu inherits Rectangle {
    in property <string> status;
    callback selected(string);

    width: 220px;
    height: 379px;
    background: #ffffff;
    border-width: 2px;
    border-color: #b8b8b8;
    border-radius: 3px;

    VerticalLayout {
        padding-top: 5px;
        padding-bottom: 5px;
        spacing: 0px;

        ContextActionItem { label: "Open"; action: "open"; enabled: root.status == "Complete"; selected(action) => { root.selected(action); } }
        ContextActionItem { label: "Open with..."; action: "open-with"; enabled: false; selected(action) => { root.selected(action); } }
        ContextActionItem { label: "Open folder"; action: "open-folder"; selected(action) => { root.selected(action); } }
        ContextActionItem { label: "Show download window"; action: "show-download-window"; selected(action) => { root.selected(action); } }
        ContextSeparator { }
        ContextActionItem { label: "Move/Rename (Ctrl-M)"; action: "move-rename"; enabled: false; selected(action) => { root.selected(action); } }
        ContextSeparator { }
        ContextActionItem { label: "Redownload"; action: "redownload"; selected(action) => { root.selected(action); } }
        ContextActionItem { label: "Resume Download"; action: "resume"; enabled: root.status == "Paused" || root.status == "Failed" || root.status == "Queued"; selected(action) => { root.selected(action); } }
        ContextActionItem { label: "Stop Download"; action: "stop"; enabled: root.status != "Complete" && root.status != "Paused"; selected(action) => { root.selected(action); } }
        ContextSeparator { }
        ContextActionItem { label: "Refresh download address"; action: "refresh-address"; selected(action) => { root.selected(action); } }
        ContextActionItem { label: "Remove"; action: "remove"; selected(action) => { root.selected(action); } }
        ContextSeparator { }
        ContextActionItem { label: "Move to queue"; action: "move-queue"; enabled: true; has-sub-menu: true; selected(action) => { root.selected(action); } }
        ContextActionItem { label: "Delete from queue"; action: "delete-queue"; enabled: false; selected(action) => { root.selected(action); } }
        ContextSeparator { }
        ContextActionItem { label: "Properties"; action: "properties"; selected(action) => { root.selected(action); } }
    }
}

component ToolbarButton inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    callback clicked();

    width: 66px;
    height: 64px;
    background: touch.pressed ? #343434 : touch.has-hover ? #2b2b2b : transparent;
    border-width: touch.has-hover ? 1px : 0px;
    border-color: #474747;

    VerticalLayout {
        padding-top: 8px;
        padding-bottom: 1px;
        spacing: 1px;

        Text {
            text: root.icon;
            font-family: "Segoe MDL2 Assets";
            color: #9bc4d6;
            font-size: 28px;
            horizontal-alignment: center;
            height: 34px;
            width: parent.width;
        }

        Text {
            text: root.label;
            color: #f2f2f2;
            font-size: 12px;
            horizontal-alignment: center;
            height: 16px;
            overflow: elide;
            width: parent.width;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component CategoryRow inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <bool> selected;
    in property <length> indent;
    callback clicked();

    height: 30px;
    background: selected ? #34383d : touch.has-hover ? #282c30 : transparent;
    border-width: selected ? 1px : 0px;
    border-color: selected ? #4e555d : transparent;
    border-radius: 4px;
    clip: true;

    HorizontalLayout {
        padding-left: 10px + root.indent;
        padding-right: 8px;
        spacing: 8px;
        alignment: start;

        Text {
            text: root.icon;
            font-family: "Segoe MDL2 Assets";
            color: selected ? #d8e9f1 : #c9c27a;
            font-size: 15px;
            width: 20px;
            height: parent.height;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            text: root.label;
            color: selected ? #ffffff : #e4e4e4;
            font-size: 13px;
            width: parent.width - 40px;
            height: parent.height;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component ActionButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary;
    in property <bool> enabled: true;
    callback clicked();

    height: 30px;
    background: !enabled ? #282b30 : touch.pressed ? (primary ? #0e84bf : #31343a) : touch.has-hover ? (primary ? #20a8e8 : #42464d) : (primary ? #1689c8 : #363a40);
    border-width: 1px;
    border-color: !enabled ? #383d43 : primary ? #35c7ff : #575e66;
    border-radius: 5px;
    clip: true;

    Text {
        text: root.label;
        color: root.enabled ? #ffffff : #8c8c8c;
        font-size: 12px;
        font-weight: 500;
        width: root.width;
        height: root.height;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        clicked => { if root.enabled { root.clicked(); } }
    }
}

component HeaderCell inherits Rectangle {
    in property <string> label;
    in property <length> cell-width;
    width: cell-width;
    height: 32px;
    background: #222528;
    border-width: 1px;
    border-color: #464c52;
    clip: true;

    Text {
        text: root.label;
        color: #f1f4f5;
        font-size: 14px;
        x: 8px;
        width: root.cell-width - 16px;
        height: root.height;
        vertical-alignment: center;
        overflow: elide;
    }
}

component FlexHeaderCell inherits Rectangle {
    in property <string> label;
    horizontal-stretch: 1;
    min-width: 120px;
    height: 32px;
    background: #222528;
    border-width: 1px;
    border-color: #464c52;
    clip: true;

    Text {
        text: root.label;
        color: #f1f4f5;
        font-size: 14px;
        x: 8px;
        width: root.width - 16px;
        height: root.height;
        vertical-alignment: center;
        overflow: elide;
    }
}

component TableCell inherits Rectangle {
    in property <string> value;
    in property <length> cell-width;
    in property <bool> selected;

    width: cell-width;
    height: 38px;
    background: transparent;
    border-width: 0px;
    border-color: transparent;
    clip: true;

    Text {
        text: root.value;
        color: selected ? #ffffff : #eeeeee;
        font-size: 13px;
        x: 8px;
        width: root.cell-width - 16px;
        height: root.height;
        vertical-alignment: center;
        overflow: elide;
    }
}

component MainProgressCell inherits Rectangle {
    in property <float> progress;
    in property <length> cell-width;
    in property <string> status;
    width: cell-width;
    height: 6px;
    background: #2b3034;
    border-width: 1px;
    border-color: #3c454b;
    border-radius: 3px;
    clip: true;

    Rectangle {
        x: 0px;
        y: 0px;
        height: parent.height;
        width: max(0px, parent.width * root.progress / 100);
        background: root.status == "Paused" ? #d58a32 : (root.status == "Failed" ? #c04747 : #21b957);
        border-radius: 3px;
    }
}

component RowStatusIcon inherits Rectangle {
    in property <string> status;
    width: 16px;
    height: 16px;
    border-radius: 8px;
    background: status == "Complete" ? #235a38 : (status == "Paused" ? #5b4545 : (status == "Failed" ? #7d3030 : #1c6c9f));
    border-width: 1px;
    border-color: status == "Complete" ? #347c4d : (status == "Paused" ? #745252 : (status == "Failed" ? #a13c3c : #2fa8e1));

    Text {
        text: status == "Complete" ? "\u{E73E}" : (status == "Paused" ? "\u{E769}" : (status == "Failed" ? "\u{E711}" : "\u{E895}"));
        font-family: "Segoe MDL2 Assets";
        color: #eaf6f6;
        font-size: 9px;
        width: parent.width;
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component FileTypeIcon inherits Rectangle {
    in property <string> category;
    width: 18px;
    height: 18px;
    background: category == "Video" ? #b9414d : (category == "Programs" ? #2a70a2 : (category == "General" ? #2b7cae : #2f6a89));
    border-width: 1px;
    border-color: #4d6c7d;
    border-radius: 3px;

    Text {
        text: category == "Video" ? "\u{E768}" : (category == "Music" ? "\u{E8D6}" : (category == "Programs" ? "\u{E756}" : (category == "Compressed" ? "\u{E8B7}" : "\u{E8A5}")));
        font-family: "Segoe MDL2 Assets";
        color: #eef8fb;
        font-size: 10px;
        width: parent.width;
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component TableRow inherits Rectangle {
    in property <string> download-id;
    in property <string> filename;
    in property <string> size;
    in property <string> status;
    in property <string> time-left;
    in property <string> rate;
    in property <string> category;
    in property <float> progress;
    in property <bool> selected;
    in property <bool> stripe;
    callback clicked(string, bool, bool);
    callback double-clicked(string);
    callback context-action(string, string);
    callback context-request(string, string, length, length);

    height: 38px;
    width: 100%;
    background: selected ? #33383d : (touch.has-hover ? #2b2f33 : (stripe ? #242628 : #1d1f21));
    border-width: 1px;
    border-color: selected ? #4f697b : #191b1d;
    clip: true;

    HorizontalLayout {
        spacing: 0px;
        Rectangle {
            horizontal-stretch: 1;
            min-width: 120px;
            height: root.height;
            background: transparent;
            clip: true;

            FileTypeIcon {
                x: 8px;
                y: (parent.height - self.height) / 2;
                category: root.category;
            }

            Text {
                text: root.filename;
                color: #f0f0f0;
                font-size: 13px;
                x: 33px;
                y: root.progress > 0 && root.progress < 100 && root.status != "Complete" ? 4px : 0px;
                width: parent.width - 41px;
                height: root.progress > 0 && root.progress < 100 && root.status != "Complete" ? 18px : parent.height;
                vertical-alignment: center;
                overflow: elide;
            }

            if root.progress > 0 && root.progress < 100 && root.status != "Complete": MainProgressCell {
                x: 33px;
                y: 27px;
                cell-width: parent.width - 41px;
                progress: root.progress;
                status: root.status;
            }
        }

        TableCell { value: root.size; cell-width: 96px; selected: root.selected; }

        Rectangle {
            width: 112px;
            height: root.height;
            background: transparent;
            clip: true;

            RowStatusIcon {
                x: 8px;
                y: (parent.height - self.height) / 2;
                status: root.status;
            }

            Text {
                text: root.status;
                color: #eeeeee;
                font-size: 13px;
                x: 31px;
                width: 74px;
                height: parent.height;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        TableCell { value: root.time-left; cell-width: 108px; selected: root.selected; }
        TableCell { value: root.rate; cell-width: 134px; selected: root.selected; }
        TableCell { value: root.category; cell-width: 120px; selected: root.selected; }
    }

    touch := TouchArea {
        double-clicked => { root.double-clicked(root.download-id); }
        pointer-event(event) => {
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                root.clicked(root.download-id, event.modifiers.control, event.modifiers.shift);
            } else if event.kind == PointerEventKind.down && event.button == PointerEventButton.right {
                root.clicked(root.download-id, false, false);
                root.context-request(root.download-id, root.status, root.absolute-position.x + touch.mouse-x, root.absolute-position.y + touch.mouse-y);
            }
        }
    }
}

component SettingsTab inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked();

    height: 32px;
    min-width: 108px;
    horizontal-stretch: 1;
    background: selected ? #123f63 : (touch.has-hover ? #25292d : transparent);
    border-width: selected ? 1px : 0px;
    border-color: selected ? #1d78b8 : transparent;
    border-radius: 4px;
    clip: true;

    Rectangle {
        visible: root.selected;
        x: 1px;
        y: parent.height - 3px;
        width: parent.width - 2px;
        height: 3px;
        background: #0078d4;
        border-radius: 0px;
    }

    Text {
        text: root.label;
        color: root.selected ? #ffffff : #c7cdd2;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component SettingsInput inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;

    height: 30px;
    background: transparent;
    border-width: 0px;
    clip: true;

    LineEdit {
        text <=> root.text;
        placeholder-text: root.placeholder;
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        font-size: 13px;
    }
}

component StatusTab inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked();

    height: 30px;
    background: selected ? #2a2d31 : touch.has-hover ? #25292d : #1c1f22;
    border-width: 1px;
    border-color: selected ? #626a72 : #31363c;
    border-radius: 5px;
    clip: true;

    Rectangle {
        visible: root.selected;
        x: 1px;
        y: parent.height - 2px;
        width: parent.width - 2px;
        height: 2px;
        background: #20a8e8;
    }

    Text {
        text: root.label;
        color: #ffffff;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component ToggleButton inherits Rectangle {
    in-out property <bool> checked;
    in property <string> label;

    height: 26px;
    background: transparent;
    border-width: 0px;
    border-color: transparent;
    clip: true;

    HorizontalLayout {
        padding-left: 0px;
        padding-right: 0px;
        spacing: 8px;
        alignment: start;

        Rectangle {
            width: 18px;
            height: 18px;
            border-width: 2px;
            border-color: root.checked ? #63b8ed : #6c7478;
            background: root.checked ? #268dca : #171a1d;
            border-radius: 4px;

            Text {
                text: root.checked ? "\u{E73E}" : "";
                font-family: "Segoe MDL2 Assets";
                color: #ffffff;
                font-size: 11px;
                width: parent.width;
                height: parent.height;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.label;
            color: #eeeeee;
            font-size: 13px;
            height: parent.height;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    touch := TouchArea {
        clicked => { root.checked = !root.checked; }
    }
}

